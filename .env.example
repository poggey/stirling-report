# FRED (St. Louis Fed) API key — free at https://fred.stlouisfed.org/docs/api/api_key.html
# Optional in development: without it the US Treasury panel shows a stale fixture.
FRED_API_KEY=

# Protects /api/cron/snapshot. Set to a long random string in Vercel;
# unset locally the route allows dev-only manual runs.
CRON_SECRET=

# Vercel Blob storage for editions. Created automatically when you add a
# Blob store to the Vercel project. Without it, editions read/write the
# repo's /data/editions folder (local dev + GitHub mirror).
BLOB_READ_WRITE_TOKEN=

# Phase 3 — Google Gemini for the daily briefings (free tier).
# Without it the deterministic template briefing serves instead.
GEMINI_API_KEY=
